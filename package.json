{
  "name": "@ublacklist/website",
  "version": "1.0.0",
  "private": true,
  "imports": {
    "#site/*": "./*"
  },
  "scripts": {
    "postinstall": "pnpm generate",
    "build": "docusaurus build",
    "check": "pnpm run /^check:/",
    "check:biome": "biome check",
    "check:prettier": "prettier --check **/*.{md,mdx,yaml,yml}",
    "check:typescript": "tsc",
    "clear": "docusaurus clear",
    "fix": "pnpm run /^fix:/",
    "fix:biome": "biome check --write",
    "fix:prettier": "prettier --write **/*.{md,mdx,yaml,yml}",
    "generate": "node community/generate.ts",
    "serve": "docusaurus serve",
    "start": "docusaurus start"
  },
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ]
  },
  "dependencies": {
    "@docusaurus/core": "3.10.2",
    "@docusaurus/faster": "3.10.2",
    "@docusaurus/preset-classic": "3.10.2",
    "@mdx-js/react": "3.1.1",
    "clsx": "2.1.1",
    "prism-react-renderer": "2.4.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@docusaurus/module-type-aliases": "3.10.2",
    "@docusaurus/theme-classic": "3.10.2",
    "@docusaurus/types": "3.10.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "js-yaml": "5.2.1",
    "lefthook": "2.1.10",
    "prettier": "3.9.5",
    "typescript": "7.0.2",
    "zod": "4.4.3"
  },
  "packageManager": "pnpm@11.11.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  }
}
