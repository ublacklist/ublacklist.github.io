{
  "name": "@ublacklist/website",
  "version": "1.0.0",
  "private": true,
  "imports": {
    "#site/*": "./*"
  },
  "scripts": {
    "postinstall": "pnpm generate",
    "build": "docusaurus build",
    "check": "pnpm run /^check:/",
    "check:biome": "biome check",
    "check:prettier": "prettier --check **/*.{md,mdx,yaml,yml}",
    "check:typescript": "tsgo",
    "clear": "docusaurus clear",
    "fix": "pnpm run /^fix:/",
    "fix:biome": "biome check --write",
    "fix:prettier": "prettier --write **/*.{md,mdx,yaml,yml}",
    "generate": "node community/generate.ts",
    "serve": "docusaurus serve",
    "start": "docusaurus start"
  },
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ]
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/faster": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/theme-classic": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@typescript/native-preview": "7.0.0-dev.20260314.1",
    "js-yaml": "^4.1.1",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.32.1",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.14.0",
      "onFail": "download"
    }
  }
}
